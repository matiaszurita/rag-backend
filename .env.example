APP_NAME=rag-backend
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_backend
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_backend
# Change this before using any non-development environment.
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
REDIS_URL=redis://localhost:6379/0
LOCAL_STORAGE_PATH=./data/documents
MAX_UPLOAD_SIZE_MB=10
LOG_LEVEL=INFO
