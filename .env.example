APP_NAME=rag-backend
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_backend
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_backend
JWT_SECRET_KEY=change-me-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
REDIS_URL=redis://redis:6379/0
LOCAL_STORAGE_PATH=./data/documents
LOG_LEVEL=INFO
