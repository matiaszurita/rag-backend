APP_NAME=rag-backend
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_backend
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_backend
# Change this before using any non-development environment.
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
REDIS_URL=redis://localhost:6379/0
LOCAL_STORAGE_PATH=./data/documents
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
MAX_UPLOAD_SIZE_MB=10
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_LLM_MODEL=models/gemini-2.5-flash
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_SEARCH_TOP_K=5
RAG_ANSWER_MAX_CONTEXT_CHUNKS=5
RAG_MIN_RELEVANCE_SCORE=0.30
LOG_LEVEL=INFO
